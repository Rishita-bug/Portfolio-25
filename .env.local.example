# Google Apps Script Web App URL for storing contact form submissions
# Follow SETUP_GOOGLE_SHEETS.md for instructions on how to get this URL
# NOTE: Vite requires VITE_ prefix (not REACT_APP_)
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID_HERE/exec

# EmailJS Configuration for sending resume emails
# Follow SETUP_EMAILJS.md for instructions on how to set this up
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
